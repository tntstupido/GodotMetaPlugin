ios.release = "res://addons/meta_sdk/ios/bin/libgodot_meta_sdk.ios.template_release.framework"

[dependencies]
ios.debug = { }
ios.release = { }

[icons]
GodotMetaSdk = "res://addons/meta_sdk/icons/godot_meta_sdk.svg"

ios/plugins/meta_install_plugin/FBAEMKit.xcframework/*/dSYMs/
ios/plugins/meta_install_plugin/FBAEMKit.xcframework/*/*/*.dSYM/

# MetaInstallPlugin xcframework internals — rebuild from source
